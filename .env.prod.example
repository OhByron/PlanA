# PlanA — Production environment
# Copy to .env.prod and fill in all values before deploying.

# Domain — Caddy uses this for automatic HTTPS via Let's Encrypt
DOMAIN=plana.yourdomain.com
PUBLIC_URL=https://plana.yourdomain.com

# PostgreSQL
POSTGRES_DB=plana
POSTGRES_USER=plana
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Redis
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Auth secrets (min 32 characters each)
JWT_SECRET=CHANGE_ME_RANDOM_32_PLUS_CHARS
ELECTRIC_JWT_SECRET=CHANGE_ME_DIFFERENT_32_PLUS_CHARS

# OAuth — GitHub App (create at https://github.com/settings/apps)
# Set callback URL to https://plana.yourdomain.com/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OAuth — Google (create at https://console.cloud.google.com/apis/credentials)
# Set callback URL to https://plana.yourdomain.com/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email (https://resend.com)
RESEND_API_KEY=
