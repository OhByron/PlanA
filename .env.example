# Root .env — used by docker-compose and local dev tooling
# Copy to .env before running: cp .env.example .env

# PostgreSQL
POSTGRES_DB=plana
POSTGRES_USER=plana
POSTGRES_PASSWORD=plana

# API
DATABASE_URL=postgresql://plana:plana@localhost:5432/plana?sslmode=disable
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-in-production-use-32-plus-chars
PORT=8080
ENV=development
APP_BASE_URL=http://localhost:8080
FRONTEND_URL=http://localhost:5173
# ALLOWED_ORIGINS=https://app.yourdomain.com  (production only)

# OAuth — GitHub App
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OAuth — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Web
VITE_API_URL=http://localhost:8080
